{
    "saa_config":{
        "saa_run_id": "00041",
        "saa_base_dir":"src/agents/RecurrPPO_target_position_agent/saved_models",
        "saa_config_id": "00009",
        "device": "cpu"
    },

  "allocator_transformer": {
        "d_model": 128,
        "n_heads": 8,
        "n_layers": 4,
        "dim_feedforward": 512,
        "dropout": 0.1,
        "activation": "relu",
        "use_asset_id_embedding": true,
        "use_portfolio_token": true
  },

  "allocator_tokenizer": {
        "portfolio_feature_dim": 8
  },

    "features": {
        "dow_sin": true,
        "dow_cos": true,
        "dom_sin": true,
        "dom_cos": true,
        "moy_sin": true,
        "moy_cos": true,
        "return_1d": true,
        "return_5d": true,
        "return_20d": true,
        "return_40d": true,
        "volume_change_1d": true,
        "volume_change_5d": true,
        "volume_change_20d": true,
        "volume_change_40d": true,
        "volume_percentile_20d": true,
        "volume_percentile_40d": true,
        "daily_range_pct": true,
        "rsi_14": true,
        "macd": true,
        "bb_position": true,
        "bb_width": true,
        "volatility_5d": true,
        "volatility_20d": true,
        "market_beta": true,
        "avg_correlation": true,
        "composite_risk_score": true,
        "return_kurtosis": true,
        "trend_strength_20d": true,
        "drawdown_adjusted_return_30d": true
    },

    "environment": {
        "assets": ["SPY", "EWG", "EWH", "EWJ", "EWQ", "EWS", "EWT", "EWU", "EWY", "Crude", "Gold"],
        "execution_mode": "portfolio_weights",
        "initial_portfolio_value": 10000,
        "episode_length_days": 252,
        "lookback_window": 0,
        "early_stopping_threshold": 0.2,
        "cash_drag_rate_pa": 0.015,
        "seed": 42,
        "maybe_provide_sequence": false,
        "block_buffer_multiplier": 1.2,
        "test_val_split_ratio": 0.1,

        "sortino_eta": 0.018,
        "lambda_drawdown": 0.005,
        "sortino_net_reward_mix": 0.5,

        "percentage_of_cash_only_starts": 0.10,

        "execution_min_share_threshold": 1,
        "execution_min_trade_value_threshold": 200.0,
        "execution_min_days_between_trades": 2,
        "execution_weight_change_threshold": 0.01,
        "allow_short": false,
        "price_source": "current_close",
        "quantity_type": "shares",

        "fixed_fee_per_order": 0.0,
        "commission_bps": 0.0002,
        "half_spread_bps": 0.0015,
        "impact_coeff": 0.125,
        "adv_window": 21
  },

    "portfolio_allocator_agent":{
        "policy_kwargs": {
        },

        "device": "auto",
        "verbose": 1,
        "n_epochs": 3,
        "n_steps": 2016,
        "batch_size": 504,
        "gamma": 0.993,
        "gae_lambda": 0.98,
        "vf_coef": 0.5,
        "max_grad_norm": 0.5,
        "target_kl": 0.05,
        "normalize_advantage": true,        

        "learning_rate_start":  1.5e-4,
        "learning_rate_end": 5.0e-5,
        "lr_schedule_type": "linear",
        "lr_schedule_warmup_pct": 0.3,
        "lr_schedule_ramping_pct": 0.6,

        "ent_coef_start": 0.005,
        "ent_coef_end": 0.0001,
        "ent_coef_schedule_type": "linear",
        "ent_coef_schedule_warmup_pct": 0.35,
        "ent_coef_schedule_ramping_pct": 0.6,

        "action_limiting_factor_start": 0.06,
        "action_limiting_factor_end": 0.09,
        "action_limiting_factor_schedule_type": "linear",
        "action_limiting_factor_schedule_warmup_pct": 0.3,
        "action_limiting_factor_schedule_ramping_pct": 0.6

    },

    "training": {
        "seed": 42,
        "total_timesteps": 2000000,
        "train_log_freq": 10,
        "eval_freq": 20000,
        "n_eval_episodes": 33,
        "eval_deterministic": false,
        "progress_bar": true,
        "config_id": 1
    }

}