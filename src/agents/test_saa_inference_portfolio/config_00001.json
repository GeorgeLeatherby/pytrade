{
  "_comment_design": "Test config for SAA portfolio inference. environment + saa_features blocks MUST match the SAA training config of the model being loaded (cache feature ordering and obs dim depend on these). The agent overrides execution_mode to 'simple' at runtime so the env accepts TradeInstruction lists.",

  "test_agent": {
    "num_episodes": 5,
    "device": "cpu",
    "saa_model_run_dir": "src/agents/RecurrPPO_target_position_agent/saved_models/00210_config_01043_26_05_10",
    "allocation_mode": "uniform",
    "deterministic_saa": true,
    "report_subdir": "reports",
    "_comment_action_factor": "Multiplicative cap applied to each SAA scalar action prior to interpretation. Should match the action_limiting_factor_end used during the SAA training so test-time action distribution mirrors deployment.",
    "action_limiting_factor": 0.05
  },

  "environment": {
    "execution_mode": "single_asset_target_position",
    "initial_portfolio_value": 10000,
    "episode_length_days": 252,
    "lookback_window": 0,
    "early_stopping_threshold": 0.2,
    "cash_drag_rate_pa": 0.015,
    "seed": 42,
    "maybe_provide_sequence": false,
    "block_buffer_multiplier": 1.2,
    "test_val_split_ratio": 0.15,

    "sortino_eta": 0.018,
    "lambda_drawdown": 0.005,
    "sortino_net_reward_mix": 0.4,

    "percentage_of_cash_only_starts": 1.0,
    "min_initial_cash_allocation": 1.0,

    "execution_min_share_threshold": 1,
    "execution_min_trade_value_threshold": 50.0,
    "execution_min_days_between_trades": 1,
    "execution_weight_change_threshold": 0.005,
    "allow_short": false,
    "price_source": "current_close",
    "quantity_type": "shares",

    "fixed_fee_per_order": 0.0,
    "commission_bps": 0.0002,
    "half_spread_bps": 0.0015,
    "impact_coeff": 0.125,
    "adv_window": 21
  },

  "saa_features": {
    "dow_sin": true,
    "dow_cos": true,
    "dom_sin": true,
    "dom_cos": true,
    "moy_sin": true,
    "moy_cos": true,
    "return_1d": true,
    "return_5d": true,
    "return_20d": true,
    "return_40d": true,
    "volume_change_1d": true,
    "volume_change_5d": true,
    "volume_change_20d": true,
    "volume_change_40d": true,
    "volume_percentile_20d": true,
    "volume_percentile_40d": true,
    "daily_range_pct": true,
    "rsi_14": true,
    "macd": true,
    "bb_position": true,
    "bb_width": true,
    "volatility_5d": true,
    "volatility_20d": true,
    "market_beta": true,
    "avg_correlation": true,
    "composite_risk_score": true,
    "return_kurtosis": true,
    "trend_strength_20d": true,
    "drawdown_adjusted_return_30d": true
  },

  "training": {
    "seed": 42,
    "action_l2_penalty_coeff": 0.0,
    "action_limiting_factor_start": 0.05
  }
}
